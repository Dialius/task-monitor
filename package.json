{
  "name": "multi-platform-class-reminder-bot",
  "version": "1.0.0",
  "description": "Multi-Platform Class Reminder Bot for Discord and WhatsApp",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ai": "node scripts/test-ai.js",
    "test:ai-enhancement": "node scripts/test-ai-enhancement.js",
    "test:formatter": "node scripts/test-formatter-output.js",
    "seed": "node scripts/seed-dummy-data.js",
    "deploy-commands": "node scripts/deploy-commands.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "backup": "node scripts/backup-db.bat",
    "cleanup-logs": "node scripts/cleanup-logs.bat"
  },
  "keywords": [
    "discord",
    "whatsapp",
    "bot",
    "reminder",
    "education",
    "multi-platform"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "discord.js": "^14.25.1",
    "dotenv": "^16.6.1",
    "groq-sdk": "^0.37.0",
    "mongoose": "^8.22.1",
    "node-cron": "^3.0.3",
    "qrcode-terminal": "^0.12.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^4.7.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/node": "^20.19.33",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "fast-check": "^3.23.2",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.3",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  }
}
