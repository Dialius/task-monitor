# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/multiplatform_class_bot

# First Admin Configuration (Bootstrap)
# Set admin pertama yang akan otomatis dibuat saat bot start
# Anda bisa set untuk Discord, WhatsApp, atau keduanya

# Discord Admin (opsional)
# User ID Discord (klik kanan user > Copy User ID)
FIRST_ADMIN_DISCORD_ID=

# WhatsApp Admin (opsional)
# Nomor HP tanpa + dan tanpa spasi (contoh: 6281234567890)
FIRST_ADMIN_WHATSAPP_ID=

# Role admin pertama (ketua, wakil, koordinator)
FIRST_ADMIN_ROLE=ketua

# Discord Configuration
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_CHANNEL_ID=
DISCORD_ENABLED=true

# ============================================
# DISCORD ACTIVITY STATUS CONFIGURATION
# ============================================
# Enable/disable rotating activity status (true/false)
DISCORD_ACTIVITY_ENABLED=true

# Rotation interval in minutes (default: 5)
# Berapa menit sekali bot ganti activity status
# Rekomendasi: 3-10 menit
DISCORD_ACTIVITY_INTERVAL=5

# Default Activity Type (WATCHING, PLAYING, LISTENING, COMPETING)
# Pilihan:
#   - WATCHING: "👀 Watching ..." (untuk monitoring/tracking)
#   - PLAYING: "🎮 Playing ..." (untuk fun/casual)
#   - LISTENING: "🎧 Listening to ..." (untuk alerts/notifications)
#   - COMPETING: "🏆 Competing in ..." (untuk challenges/motivation)
# Bisa di-override per template di config file
DISCORD_ACTIVITY_TYPE=WATCHING

# Template Variables yang bisa digunakan di config file:
#   {total}    = Total tugas aktif (contoh: "5")
#   {active}   = Sama dengan {total} (contoh: "5")
#   {nearest}  = Deadline terdekat (contoh: "16 Feb")
#   {today}    = Tugas hari ini (contoh: "3")
#   {percent}  = Persentase completion rate (contoh: "75")
#   {urgent}   = Tugas urgent < 24 jam (contoh: "2")
#   {hours}    = Jam sampai deadline terdekat (contoh: "5")
#
# Contoh templates (edit di src/config/discord.config.ts):
#   - "{total} tasks" → "5 tasks"
#   - "{today} tasks today" → "3 tasks today"
#   - "{percent}% completion rate" → "75% completion rate"
#   - "{urgent} urgent | {hours}h left" → "2 urgent | 5h left"
#
# Lihat DISCORD_ACTIVITY_GUIDE.md untuk panduan lengkap

# ============================================
# DISCORD TASK MONITOR CONFIGURATION
# ============================================
# Channel untuk Task Monitor embed (info channel)
# Cara dapat: Klik kanan channel > Copy Channel ID
DISCORD_INFO_CHANNEL_ID=

# Channel untuk member commands
# Cara dapat: Klik kanan channel > Copy Channel ID
DISCORD_COMMAND_CHANNEL_ID=

# ============================================
# DISCORD ANIMATED EMOJIS
# ============================================
# Format: <a:name:ID>
# Get from Discord Developer Portal > Your App > Emojis
# Upload emoji animated ke Discord Developer Portal dulu
DISCORD_EMOJI_ONLINE=<a:online:ID>
DISCORD_EMOJI_OFFLINE=<a:offline:ID>
DISCORD_EMOJI_CLOCK=<a:clock:ID>
DISCORD_EMOJI_LOADING=<a:loading:ID>
DISCORD_EMOJI_CALENDAR=<a:calendar:ID>
DISCORD_EMOJI_TASK=<a:task:ID>
DISCORD_EMOJI_INDIVIDUAL=<a:individu:ID>
DISCORD_EMOJI_GROUP=<a:group:ID>
DISCORD_EMOJI_SUCCESS=<a:success:ID>
DISCORD_EMOJI_ERROR=<a:error:ID>

# ============================================
# DISCORD EMBED STYLING
# ============================================
# Embed color (hex format, default: Discord Blurple)
DISCORD_EMBED_COLOR=#5865F2

# Footer icon URL (upload image dan copy URL)
DISCORD_FOOTER_ICON=https://i.imgur.com/AfFp7pu.png

# ============================================
# DISCORD RATE LIMITING
# ============================================
# General rate limit in seconds (for non-admin users)
# Default: 30 seconds
DISCORD_RATE_LIMIT_GENERAL=30

# Command channel rate limit in seconds (for non-admin users)
# Default: 7200 seconds = 2 hours
# Admin users bypass all rate limits
DISCORD_RATE_LIMIT_COMMAND=7200

# WhatsApp Configuration
WHATSAPP_ENABLED=true
WHATSAPP_GROUP_ID=
# Testing Mode - HANYA UNTUK TESTING! Set false saat production
# WHATSAPP_TESTING_MODE=false

# AI Service Configuration - Groq (Primary)
GROQ_API_KEY=
# Model yang tersedia (2025):
# - llama-3.3-70b-versatile (recommended, 280 T/sec)
# - llama-3.1-8b-instant (fastest, 560 T/sec)
# - openai/gpt-oss-120b (500 T/sec)
# - openai/gpt-oss-20b (fastest, 1000 T/sec)
GROQ_MODEL=llama-3.3-70b-versatile

# AI Service Configuration - Gemini (Fallback)
GEMINI_API_KEY=
# Model yang tersedia:
# - gemini-2.5-flash (recommended, balanced)
# - gemini-2.5-pro (advanced thinking)
# - gemini-2.5-flash-lite (fastest)
GEMINI_MODEL=gemini-2.5-flash

# Notion Integration (Optional)
NOTION_DATABASE_ID=
NOTION_API_KEY=

# Scheduler Configuration
TIMEZONE=Asia/Jakarta
DAILY_REMINDER_TIME=17:00
WEEKLY_REMINDER_DAY=5
WEEKLY_REMINDER_TIME=20:00

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs

# AI Service Timeout (seconds)
AI_TIMEOUT=10
