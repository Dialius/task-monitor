# ========================== [[[ CLASS REMINDER BOT CONFIG ]]] ==========================

# --------=========== DATABASE SETTINGS ===========--------
MONGODB_URI=mongodb://localhost:27017/task_monitor_bot    # MongoDB connection string

# --------=========== FIRST ADMIN (BOOTSTRAP) ===========--------
FIRST_ADMIN_DISCORD_ID=                        # Discord User ID (Right click user > Copy User ID)
FIRST_ADMIN_WHATSAPP_ID=                       # WhatsApp number without + (Ex: 6281234567890)
FIRST_ADMIN_ROLE=ketua                         # Role: ketua / wakil / koordinator

# --------=========== DISCORD SETTINGS ===========--------
DISCORD_ENABLED=true                           # Enable Discord bot (true/false)
DISCORD_BOT_TOKEN=                             # Bot token from Discord Developer Portal
DISCORD_CLIENT_ID=                             # Application ID from Discord Developer Portal
DISCORD_GUILD_ID=                              # Server ID (Right click server > Copy Server ID)
DISCORD_CHANNEL_ID=                            # Channel ID (Right click channel > Copy Channel ID)

# Discord Role Permissions (comma-separated role IDs)
DISCORD_ADMIN_ROLE_IDS=                        # Admin roles (Koordinator) - Can use admin commands
DISCORD_LEADER_ROLE_IDS=                       # Leader roles (Ketua/Wakil) - Can use leader + admin commands

# Discord Activity Status
DISCORD_ACTIVITY_ENABLED=true                  # Enable rotating activity status (true/false)
DISCORD_ACTIVITY_INTERVAL=5                    # Rotation interval in minutes (default: 5)
DISCORD_ACTIVITY_TYPE=3                        # 0=Playing, 2=Listening, 3=Watching, 5=Competing
DISCORD_BOT_STATUS=online                      # Bot status: online / idle / dnd / invisible

# Discord Task Monitor
DISCORD_INFO_CHANNEL_ID=                       # Channel for Task Monitor embed
DISCORD_COMMAND_CHANNEL_ID=                    # Channel for member commands
DISCORD_LOG_CHANNEL_ID=                        # Channel for error logs and sync status

# Discord Animated Emojis (Format: <a:name:ID>)
DISCORD_EMOJI_ONLINE=<a:online:ID>
DISCORD_EMOJI_OFFLINE=<a:offline:ID>
DISCORD_EMOJI_CLOCK=<a:clock:ID>
DISCORD_EMOJI_LOADING=<a:loading:ID>
DISCORD_EMOJI_CALENDAR=<a:calendar:ID>
DISCORD_EMOJI_TASK=<a:task:ID>
DISCORD_EMOJI_INDIVIDUAL=<a:individu:ID>
DISCORD_EMOJI_GROUP=<a:group:ID>
DISCORD_EMOJI_SUCCESS=<a:success:ID>
DISCORD_EMOJI_ERROR=<a:error:ID>

# Discord Embed Styling
DISCORD_EMBED_COLOR=#5865F2                    # Embed color (hex format)
DISCORD_FOOTER_ICON=https://i.imgur.com/AfFp7pu.png

# Discord Rate Limiting (seconds)
DISCORD_RATE_LIMIT_GENERAL=30                  # General rate limit for non-admin users
DISCORD_RATE_LIMIT_COMMAND=7200                # Command channel rate limit (2 hours)

# --------=========== WHATSAPP SETTINGS ===========--------
WHATSAPP_ENABLED=true                          # Enable WhatsApp bot (true/false)
WHATSAPP_GROUP_ID=                             # WhatsApp group ID (will appear in console on first connect)
WHATSAPP_USE_PAIRING_CODE=false                # Use pairing code instead of QR (better for server)
WHATSAPP_USE_MONGO_AUTH=true                   # Store WA session in MongoDB (true=persistent, false=file-based)
WHATSAPP_TESTING_MODE=false                    # Allow bot to process messages from self (TESTING ONLY!)

# --------=========== AI SERVICE SETTINGS ===========--------
# Groq API (Primary AI Service) - Get key from: https://console.groq.com/keys
GROQ_API_KEY=                                  # Groq API key (free tier available)
GROQ_MODEL=llama-3.3-70b-versatile             # Model: llama-3.3-70b-versatile / llama-3.1-8b-instant

# Google Gemini API (Fallback AI Service) - Get key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=                                # Gemini API key (free tier available)
GEMINI_MODEL=gemini-2.5-flash                  # Model: gemini-2.5-flash / gemini-2.5-pro

AI_TIMEOUT=10                                  # AI timeout in seconds

# --------=========== NOTION INTEGRATION ===========--------
NOTION_ENABLED=false                           # Enable Notion integration (true/false)
NOTION_DATABASE_ID=                            # Notion database ID (from database URL)
NOTION_API_KEY=                                # Notion API key (from https://www.notion.so/my-integrations)

# --------=========== SCHEDULER SETTINGS ===========--------
TIMEZONE=Asia/Jakarta                          # Timezone (default: Asia/Jakarta)
DAILY_REMINDER_TIME=17:00                      # Daily reminder time (HH:MM format)
WEEKLY_REMINDER_DAY=5                          # Weekly reminder day (0=Sunday, 1=Monday, ..., 6=Saturday)
WEEKLY_REMINDER_TIME=20:00                     # Weekly reminder time (HH:MM format)

# --------=========== LOGGING SETTINGS ===========--------
LOG_LEVEL=info                                 # Log level: error / warn / info / debug
LOG_DIR=./logs                                 # Log directory path

# --------=========== API SERVER (OPTIONAL - DISABLED) ===========--------
API_ENABLED=false                              # Enable API server for dashboard (true/false)
API_PORT=3001                                  # API server port
JWT_SECRET=change-this-secret-key              # JWT secret (change this!)
JWT_EXPIRY=24h                                 # JWT token expiry
REFRESH_TOKEN_EXPIRY=7d                        # Refresh token expiry
DASHBOARD_DEFAULT_USERNAME=admin               # Default dashboard username
DASHBOARD_DEFAULT_PASSWORD=admin123            # Default dashboard password
FRONTEND_URL=http://localhost:5173             # Frontend URL for CORS
CORS_ORIGINS=http://localhost:5173             # CORS origins (comma-separated)
RATE_LIMIT_WINDOW=60000                        # Rate limit window (ms)
RATE_LIMIT_MAX=100                             # Max requests per window

# ========================== [[[ END OF CONFIG ]]] ==========================
# Notes:
# - Minimal 1 platform harus enabled (Discord atau WhatsApp)
# - AI services opsional (bot tetap jalan tanpa AI)
# - Notion integration opsional
# - Jangan share file .env ke public!
# - Restart bot setelah ubah konfigurasi
